rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function isAdminOrRole(role) {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == role);
    }

    // ========================================================================
    // USERS
    // ========================================================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
      allow create: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
      allow update: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
      allow delete: if hasRole('admin');
    }
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ========================================================================
    // MENU
    // ========================================================================
    match /menu/{itemId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ========================================================================
    // ORDERS
    // v1 FREE MODE: Clients write orders directly (no Cloud Functions needed).
    // When upgrading to Blaze + Cloud Functions, set: allow create: if false;
    // ========================================================================
    match /orders/{orderId} {
      allow read: if true;

      allow create: if (
        isAuthenticated() && request.resource.data.userId == request.auth.uid
      ) || (
        request.resource.data.userId is string &&
        request.resource.data.userId.matches("guest_.*")
      );

      // Allow cashier/admin/server to update orders
      // Allow students to update 'notifiedAt' (persistent acknowledgment)
      allow update: if isAuthenticated() && (
        getUserRole() == 'admin' || 
        getUserRole() == 'cashier' || 
        getUserRole() == 'server' ||
        (request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifiedAt']))
      );

      allow delete: if hasRole('admin');
    }

    // ========================================================================
    // INVENTORY — Read-only from client; write only via Cloud Functions
    // Students/guests can read inventory_meta for real-time stock visibility
    // ========================================================================
    match /inventory/{itemId} {
      allow read: if isAuthenticated() && (hasRole('admin') || hasRole('server') || hasRole('cashier'));
      allow write: if hasRole('admin') || hasRole('server');
    }

    // Real-time stock for students/guests: read inventory_meta (totalStock, consumed, available, stockStatus)
    match /inventory_meta/{itemId} {
      // Allow public read access (including guest/unauthenticated) for non-sensitive aggregate stock data
      allow read: if true;
      allow write: if hasRole('admin') || hasRole('server');
    }
    match /inventory_shards/{itemId}/shards/{shardId} {
      allow read: if isAuthenticated() && (hasRole('admin') || hasRole('server') || hasRole('cashier'));
      // Allow anyone to increment shards (controlled via app logic + transaction)
      allow write: if true; 
    }

    // ========================================================================
    // SETTINGS
    // ========================================================================
    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasRole('admin');
    }

    // ========================================================================
    // SCAN LOGS — Create only via Cloud Functions
    // ========================================================================
    match /scanLogs/{logId} {
      allow read: if isAdminOrRole('server');
      allow create: if isAdminOrRole('server');
      allow update, delete: if hasRole('admin');
    }

    // ========================================================================
    // SERVE LOGS — Create only via Cloud Functions
    // ========================================================================
    match /serveLogs/{logId} {
      allow read: if isAdminOrRole('server');
      allow create: if isAdminOrRole('server');
      allow update, delete: if hasRole('admin');
    }

    // ========================================================================
    // DAILY REPORTS
    // ========================================================================
    match /dailyReports/{reportId} {
      allow read: if isAuthenticated() && isAdminOrRole('cashier');
      allow write: if hasRole('admin');
    }

    // ========================================================================
    // CARTS — Client can write own cart
    // ========================================================================
    match /carts/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ========================================================================
    // FRAUD FLAGS — Written by Cloud Functions; read admin only
    // ========================================================================
    match /flags/{flagId} {
      allow read: if isAuthenticated() && hasRole('admin');
      allow write: if false;
    }

    // ========================================================================
    // FRAUD LOGS — Failed/duplicate scans, expired QR (Functions only)
    // ========================================================================
    match /fraudLogs/{logId} {
      allow read: if isAuthenticated() && hasRole('admin');
      allow write: if false;
    }

    // Notification delivery logs (Cloud Functions only; admin analytics)
    match /notificationLogs/{logId} {
      allow read: if isAuthenticated() && hasRole('admin');
      allow create, update, delete: if false;
    }

    // Smart kitchen: preparation station config (slot limits); read by server/admin, write by admin
    match /preparationStations/{stationId} {
      allow read: if isAuthenticated() && (hasRole('admin') || hasRole('server'));
      allow write: if hasRole('admin');
    }

    // Idempotency keys for Spark plan client-side ordering
    match /idempotency_keys/{keyId} {
      // Allow read/create for everyone (including guests) to support duplicate check in transactions
      allow read, create: if true;
    }

    // ========================================================================
    // PREPARATION BATCHES (Smart Kitchen)
    // ========================================================================
    match /prepBatches/{batchId} {
      allow read: if true; // Students need to read status for notifications
      allow write: if isAdminOrRole('server');
    }
  }
}
