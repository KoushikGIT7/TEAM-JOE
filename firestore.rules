rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getRawRole() {
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getRawRole() in ['ADMIN', 'SERVER', 'CASHIER', 'COOK', 'admin', 'server', 'cashier', 'cook']);
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getRawRole() in ['ADMIN', 'admin']);
    }

    function isCashier() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getRawRole() in ['ADMIN', 'CASHIER', 'admin', 'cashier']);
    }

    function isServer() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getRawRole() in ['ADMIN', 'SERVER', 'admin', 'server']);
    }

    match /menu/{itemId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /inventory_meta/{itemId} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if request.auth != null;
      
      match /items/{itemId} {
        allow read, write: if request.auth != null;
      }
    }

    match /prepBatches/{batchId} {
      allow read, write: if request.auth != null;
      allow delete: if isAdmin();
    }

    match /slot_stats/{slotId} {
      allow read: if true;
      allow write: if true;
    }

    match /carts/{userId} {
      allow read, write: if true;
    }

    match /idempotency_keys/{keyId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if true;
    }

    match /scanLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /serveLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /system/{docId} {
      allow read, write: if isStaff();
    }

    match /dailyReports/{reportId} {
      allow read: if isCashier();
      allow write: if isAdmin();
    }

    match /payments_ledger/{utrId} {
      allow read, write: if isStaff();
    }

    match /system_messages/{msgId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /system_locks/{lockId} {
      allow read, write: if isStaff();
    }

    match /system_status/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    match /{path=**}/items/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
