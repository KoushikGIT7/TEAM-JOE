rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS ─────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // Safe role lookup — returns 'student' if user doc missing or has no role field
      let data = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return ('role' in data) ? data.role.lower() : 'student';
    }

    function hasRoleDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Staff: email prefix fast-track OR Firestore role doc OR custom claim
    function isStaff() {
      let email = ('email' in request.auth.token) ? request.auth.token.email.lower() : '';
      let staffEmail = email != '' && email.matches('^(admin|server|cashier|cook|assistant)@.*');
      let tokenRole = ('role' in request.auth.token) ? request.auth.token.role.lower() : '';
      let staffClaim = tokenRole in ['admin', 'server', 'cashier', 'cook', 'manager', 'assistant_supervisor'];
      return isAuthenticated() && (
        staffEmail ||
        staffClaim ||
        (hasRoleDoc() && getUserRole() in ['admin', 'server', 'cashier', 'cook', 'manager', 'assistant_supervisor'])
      );
    }

    function isAdmin() {
      let email = ('email' in request.auth.token) ? request.auth.token.email.lower() : '';
      let tokenRole = ('role' in request.auth.token) ? request.auth.token.role.lower() : '';
      return isAuthenticated() && (
        (email != '' && email.matches('^admin@.*')) ||
        tokenRole == 'admin' ||
        (hasRoleDoc() && getUserRole() == 'admin')
      );
    }

    function isCashier() {
      let email = ('email' in request.auth.token) ? request.auth.token.email.lower() : '';
      let tokenRole = ('role' in request.auth.token) ? request.auth.token.role.lower() : '';
      return isStaff() && (
        (email != '' && email.matches('^(admin|cashier)@.*')) ||
        tokenRole in ['admin', 'cashier'] ||
        (hasRoleDoc() && getUserRole() in ['admin', 'cashier'])
      );
    }

    // ─── MENU — Read public, Write admin only ─────────────────────────────────
    match /menu/{itemId} {
      allow read: if true;           // Students + guests can browse menu
      allow write: if isAdmin();     // Only admin can add/edit/delete items
    }

    // ─── SETTINGS — Read public, Write admin only ─────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── SLOT STATS — Read public, Write authenticated ────────────────────────
    match /slot_stats/{slotId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ─── CARTS — Own user only ────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // ─── INVENTORY (legacy) — Staff only ─────────────────────────────────────
    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // ─── INVENTORY META — Read auth, Write staff (Students can only increment consumed) ──────────────
    match /inventory_meta/{itemId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isStaff() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['consumed', 'updatedAt'])
      );
      allow create: if isAuthenticated() && (
        isStaff() ||
        request.resource.data.keys().hasOnly(['consumed', 'updatedAt'])
      );
      allow delete: if isStaff();
    }

    // ─── INVENTORY SHARDS — Auth read, Auth write (shard counter) ─────────────
    match /inventory_shards/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      match /shards/{shardId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ─── SYSTEM MESSAGES ──────────────────────────────────────────────────────
    match /system_messages/{msgId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /system_status/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // ─── ORDERS ───────────────────────────────────────────────────────────────
    // Students: create own orders + read own orders
    // Students: cannot write critical status fields (qrStatus, orderStatus, etc.)
    // Staff: full read/write
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();

      // Students can update own orders but NEVER critical status fields
      // Staff can update anything
      allow update: if isAuthenticated() && (
        isStaff() ||
        (
          request.auth.uid == resource.data.userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'qrStatus', 'qrState', 'orderStatus', 'paymentStatus',
            'serveFlowStatus', 'kitchenStatus', 'confirmedBy', 'confirmedAt',
            'rejectedBy', 'rejectedAt', 'scannedAt', 'servedAt'
          ])
        )
      );

      // Only staff or the order owner can delete
      allow delete: if isStaff();

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // ─── PREP BATCHES ─────────────────────────────────────────────────────────
    match /prepBatches/{batchId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isStaff();
    }

    // ─── SYSTEM LOCKS ─────────────────────────────────────────────────────────
    match /system_locks/{lockId} {
      allow read, write: if isAuthenticated();
    }

    // ─── IDEMPOTENCY KEYS ─────────────────────────────────────────────────────
    match /idempotency_keys/{keyId} {
      allow read, create: if isAuthenticated();
      allow update: if false;
      allow delete: if isStaff();
    }

    // ─── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if (isAuthenticated() && request.auth.uid == userId) || isStaff();
      // isStaff() covers cashier confirming cash orders (transaction updates user points)
      allow write: if (isAuthenticated() && request.auth.uid == userId) || isStaff();
    }

    // ─── LOGS ─────────────────────────────────────────────────────────────────
    match /scanLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /serveLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ─── FINANCE ──────────────────────────────────────────────────────────────
    match /dailyReports/{reportId} {
      allow read: if isCashier();
      allow write: if isAdmin();
    }

    // ─── DAILY STATS (aggregation) ────────────────────────────────────────────
    match /dailyStats/{dateId} {
      allow read: if isStaff();
      allow write: if isAuthenticated(); // background increment after order serve
    }

    match /payments_ledger/{utrId} {
      allow read, write: if isStaff();
    }

    // ─── NOTIFICATION LOGS ────────────────────────────────────────────────────
    match /notificationLogs/{logId} {
      allow read: if isStaff();
      allow write: if isAuthenticated();
    }

    // ─── COLLECTIONGROUP: items subcollection ─────────────────────────────────
    match /{path=**}/items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── JOE WALLET ───────────────────────────────────────────────────────────

    // wallet_recharge_requests
    // Students: create own requests, read own requests
    // Cashier/Admin: read all + update (approve/reject)
    match /wallet_recharge_requests/{reqId} {
      allow read: if isAuthenticated() && (
        isStaff() ||
        (resource != null && request.auth.uid == resource.data.uid)
      );
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.uid &&
        request.resource.data.status == 'pending';
      allow update: if isCashier(); // approve/reject
      allow delete: if isAdmin();
    }

    // wallet_transactions
    // Students: read own; Staff: read all; nobody writes directly from client
    // All writes happen inside server-side runTransaction() calls
    match /wallet_transactions/{txId} {
      allow read: if isAuthenticated() && (
        isStaff() ||
        (resource != null && request.auth.uid == resource.data.uid)
      );
      // Transactions are created inside Firestore runTransaction (SDK auth context)
      // We allow create only from authenticated users (runTransaction runs as the user)
      allow create: if isAuthenticated();
      allow update, delete: if false; // immutable audit trail
    }
  }
}
