rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getRawRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return isAuthenticated() && (
        getRawRole() in ['ADMIN', 'SERVER', 'CASHIER', 'COOK', 'admin', 'server', 'cashier', 'cook']
      );
    }

    function isAdmin() {
      return isAuthenticated() && (getRawRole() == 'ADMIN' || getRawRole() == 'admin');
    }

    function isCashier() {
      return isAuthenticated() && (getRawRole() in ['ADMIN', 'CASHIER', 'admin', 'cashier']);
    }

    function isServer() {
      return isAuthenticated() && (getRawRole() in ['ADMIN', 'SERVER', 'admin', 'server']);
    }

    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /inventory_meta/{itemId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create: if (
          isAuthenticated() && request.resource.data.userId == request.auth.uid
        ) || (
          request.resource.data.userId is string && request.resource.data.userId.matches('guest_.*')
        );

      allow update: if (isStaff() && (
        // CASE A: CASHIER CONFIRMATION
        (isCashier() && 
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['paymentStatus', 'qrStatus', 'qr', 'confirmedBy', 'confirmedAt', 'updatedAt']) &&
         resource.data.paymentStatus != 'SUCCESS' &&
         request.resource.data.paymentStatus == 'SUCCESS' &&
         request.resource.data.confirmedBy == request.auth.uid &&
         request.resource.data.items == resource.data.items &&
         request.resource.data.totalAmount == resource.data.totalAmount &&
         request.resource.data.updatedAt == request.time &&
         request.resource.data.confirmedAt == request.time &&
         request.resource.data.qr.createdAt == request.time 
        ) ||
        // CASE B: KITCHEN WORKFLOW & MAINTENANCE
        (isStaff() && 
         request.resource.data.diff(resource.data).affectedKeys()
           .hasAny([
             'kitchenStatus', 'serveFlowStatus', 'items', 'pickupWindow', 
             'estimatedReadyTime', 'updatedAt', 'arrivalTimeSlot', 
             'batchIds', 'missedCount', 'orderStatus', 'qrStatus', 'qrState',
             'scannedAt', 'qrStatus'
           ]) &&
         request.resource.data.updatedAt == request.time
        )
      )) || (isAuthenticated() && request.auth.uid == resource.data.userId);

      allow delete: if isAdmin();
      
      match /items/{itemId} {
        allow read: if true;
        allow create: if true;
        allow update: if isStaff();
      }
    }

    match /prepBatches/{batchId} {
      allow read: if true;
      allow create, update: if isStaff() || true;
      allow delete: if isAdmin();
    }

    match /slot_stats/{slotId} {
      allow read: if true;
      allow write: if true;
    }

    match /idempotency_keys/{keyId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read, write: if isStaff();
    }

    match /scanLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /serveLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /system/{docId} {
      allow read, write: if isStaff();
    }

    match /dailyReports/{reportId} {
      allow read: if isCashier();
      allow write: if isAdmin();
    }
  }
}
