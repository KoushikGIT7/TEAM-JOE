rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.role : 'GUEST';
    }

    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }

    function isAdminOrRole(role) {
      return isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == role);
    }

    // --- CRITICAL SPARK PLAN RULES (Public Transactions) ---
    match /slot_stats/{slotId} {
      allow read, write: if true;
    }
    match /prepBatches/{batchId} {
      allow read, write: if true;
    }
    match /idempotency_keys/{keyId} {
      allow read, write: if true;
    }
    match /inventory_shards/{itemId}/shards/{shardId} {
      allow read, write: if true;
    }

    // --- USERS ---
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || hasRole('ADMIN'));
      allow delete: if hasRole('ADMIN');
    }
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // --- MENU ---
    match /menu/{itemId} {
      allow read: if true;
      allow write: if hasRole('ADMIN');
    }

    // --- ORDERS ---
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true; // Open creation for Spark Plan (app logic controls)
      allow update: if (
        isAdminOrRole('SERVER') || isAdminOrRole('CASHIER')
      ) || (
        (isAuthenticated() && request.auth.uid == resource.data.userId) ||
        (resource.data.userId.matches("guest_.*"))
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['notifiedAt', 'updatedAt']);
      allow delete: if hasRole('ADMIN');
    }

    // --- INVENTORY ---
    match /inventory/{itemId} {
      allow read: if isAdminOrRole('SERVER') || isAdminOrRole('CASHIER');
      allow write: if isAdminOrRole('SERVER');
    }
    match /inventory_meta/{itemId} {
      allow read: if true;
      allow write: if isAdminOrRole('SERVER');
    }

    // --- SETTINGS ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasRole('ADMIN');
    }

    // --- LOGS & ANALYTICS ---
    match /scanLogs/{logId} {
      allow read, create: if isAdminOrRole('SERVER');
      allow update, delete: if hasRole('ADMIN');
    }
    match /serveLogs/{logId} {
      allow read, create: if isAdminOrRole('SERVER');
      allow update, delete: if hasRole('ADMIN');
    }
    match /dailyReports/{reportId} {
      allow read: if isAdminOrRole('CASHIER');
      allow write: if hasRole('ADMIN');
    }
    match /carts/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    match /flags/{flagId} {
      allow read: if hasRole('ADMIN');
      allow write: if false;
    }
    match /fraudLogs/{logId} {
      allow read: if hasRole('ADMIN');
      allow write: if false;
    }
    match /notificationLogs/{logId} {
      allow read: if hasRole('ADMIN');
      allow create, update, delete: if false;
    }
    match /preparationStations/{stationId} {
      allow read: if isAdminOrRole('SERVER');
      allow write: if hasRole('ADMIN');
    }
  }
}
