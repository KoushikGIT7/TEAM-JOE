rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPERS ─────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // Safe read of the role field, forcing to lowercase for normalized comparison
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower();
    }

    function hasRoleDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // 🛡️ [STAFF-RESOLVER]: Determines if the session belongs to legitimate operations.
    // Handles case-insensitive roles and provides an email-prefix fast-track for zero-lag UI.
    function isStaff() {
      let email = request.auth.token.email.lower();
      let staffEmail = email.matches('^(admin|server|cashier|cook)@.*');
      return isAuthenticated() && (
        staffEmail ||
        (hasRoleDoc() && getUserRole() in ['admin', 'server', 'cashier', 'cook', 'manager'])
      );
    }

    function isAdmin() {
      let email = request.auth.token.email.lower();
      return isAuthenticated() && (
        email.matches('^admin@.*') ||
        (hasRoleDoc() && getUserRole() == 'admin')
      );
    }

    function isCashier() {
      return isStaff() && (
        request.auth.token.email.lower().matches('^(admin|cashier)@.*') ||
        (hasRoleDoc() && getUserRole() in ['admin', 'cashier'])
      );
    }

    // ─── PUBLIC / OPEN COLLECTIONS ────────────────────────────────────────────

    match /menu/{itemId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /slot_stats/{slotId} {
      allow read, write: if true;
    }

    match /carts/{userId} {
      allow read, write: if true;
    }

    match /inventory/{itemId} {
      allow read, write: if true;
    }

    match /inventory_meta/{itemId} {
      allow read, write: if true;
    }

    // ─── INVENTORY SHARDS ─────────────────────────────────────────────────────
    // Written by staff on each QR serve (atomic shard increment).
    // Read for aggregated stock calculation in admin/inventory panels.
    match /inventory_shards/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();

      match /shards/{shardId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    match /system_messages/{msgId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /system_status/{docId} {
      allow read: if true;
      allow write: if isAuthenticated(); // metrics written by any logged-in user
    }

    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // ─── ORDERS ────────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      allow read, write: if isAuthenticated();

      match /items/{itemId} {
        allow read, write: if isAuthenticated();
      }
    }

    // ─── PREP BATCHES ─────────────────────────────────────────────────────────
    // Batch generator, cooks, and servers all need full read/write.
    // Any authenticated user can read (student order tracking).
    // Only staff may create/update; only admin may delete.

    match /prepBatches/{batchId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated(); // generator runs as logged-in staff
      allow delete: if isStaff();
    }

    // ─── SYSTEM LOCKS ─────────────────────────────────────────────────────────
    // 🛡️ [ROOT-FIX]: Coordination locks are pure operational signaling.
    // Restricting these to isStaff() caused pulse failure for non-prefixed staff emails.
    // Relaxed to isAuthenticated() to ensure background stability across all client nodes.
    match /system_locks/{lockId} {
      allow read, write: if isAuthenticated();
    }

    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // ─── IDEMPOTENCY KEYS ─────────────────────────────────────────────────────

    match /idempotency_keys/{keyId} {
      allow read, create: if isAuthenticated();
      allow update: if false;
      allow delete: if isStaff();
    }

    // ─── USERS ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    // ─── LOGS ─────────────────────────────────────────────────────────────────

    match /scanLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /serveLogs/{logId} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ─── FINANCE ──────────────────────────────────────────────────────────────

    match /dailyReports/{reportId} {
      allow read: if isCashier();
      allow write: if isAdmin();
    }

    match /payments_ledger/{utrId} {
      allow read, write: if isStaff();
    }

    // ─── COLLECTIONGROUP: items subcollection ─────────────────────────────────
    // Batch generator uses collectionGroup('items') to find PENDING items across
    // all orders in a single indexed query. This must be readable by any
    // authenticated user (staff) and writable by authenticated users.

    match /{path=**}/items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
